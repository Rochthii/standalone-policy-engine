# PostgreSQL database connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/policy_engine?sslmode=disable

# Redis URL and Client Mode (single, sentinel, cluster)
REDIS_URL=localhost:6379
REDIS_MODE=single

# JWT Secret key for incoming gRPC metadata tokens validation
# Generate with: openssl rand -base64 48 | tr -d '\n'
JWT_SECRET=<your-random-secret-key-minimum-32-characters>

# Key Encrypting Key (KEK) for AES-GCM log envelope encryption
# CRITICAL: Must be EXACTLY 32 bytes (256-bit) for AES-256-GCM
# Generate with: openssl rand -base64 24 | head -c 32
LOG_KEK=<your-exactly-32-byte-aes-256-gcm-key!!>

# Garbage Collection (GC) configurations for Tenant RAM Engine Cache
GC_ENABLED=true
GC_INTERVAL=10m
GC_IDLE_TIMEOUT=24h
GC_MAX_CACHE_SIZE=1000
